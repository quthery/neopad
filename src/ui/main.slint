component SuggestionItem inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <color> accent;
    in property <int> icon-kind;

    background: #ffffff07;
    border-width: 1px;
    border-color: #ffffff0e;
    border-radius: 8px;

    Rectangle {
        x: 11px;
        y: (parent.height - self.height) / 2;
        width: 34px;
        height: 34px;
        border-radius: 9px;
        background: accent;
        opacity: 0.18;
    }

    Rectangle {
        x: 20px;
        y: 17px;
        width: 16px;
        height: 16px;
        border-radius: 5px;
        border-width: 2px;
        border-color: accent;
        background: transparent;
        visible: icon-kind == 0;
    }

    Rectangle {
        x: 23px;
        y: 21px;
        width: 10px;
        height: 2px;
        border-radius: 1px;
        background: accent;
        visible: icon-kind == 0;
    }

    Rectangle {
        x: 24px;
        y: 25px;
        width: 8px;
        height: 2px;
        border-radius: 1px;
        background: accent;
        visible: icon-kind == 0;
    }

    Path {
        x: 19px;
        y: 14px;
        width: 18px;
        height: 22px;
        commands: "M 3 1 L 12 1 L 17 6 L 17 21 L 3 21 Z M 12 1 L 12 6 L 17 6";
        fill: transparent;
        stroke: accent;
        stroke-width: 1.8px;
        visible: icon-kind == 1;
    }

    Rectangle {
        x: 24px;
        y: 24px;
        width: 8px;
        height: 2px;
        border-radius: 1px;
        background: accent;
        visible: icon-kind == 1;
    }

    Rectangle {
        x: 24px;
        y: 29px;
        width: 8px;
        height: 2px;
        border-radius: 1px;
        background: accent;
        visible: icon-kind == 1;
    }

    Rectangle {
        x: 20px;
        y: 16px;
        width: 15px;
        height: 15px;
        border-radius: 8px;
        border-width: 2px;
        border-color: accent;
        background: transparent;
        visible: icon-kind == 2;
    }

    Path {
        x: 31px;
        y: 28px;
        width: 8px;
        height: 8px;
        commands: "M 1 1 L 7 7";
        fill: transparent;
        stroke: accent;
        stroke-width: 2px;
        visible: icon-kind == 2;
    }

    Text {
        x: 56px;
        y: 9px;
        width: parent.width - 68px;
        height: 20px;
        text: title;
        color: #ffffffe8;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: left;
        vertical-alignment: center;
    }

    Text {
        x: 56px;
        y: 29px;
        width: parent.width - 68px;
        height: 16px;
        text: subtitle;
        color: #ffffff78;
        font-size: 11px;
        font-weight: 500;
        horizontal-alignment: left;
        vertical-alignment: center;
    }
}

export component AppWindow inherits Window {
    width: root.screen-width;
    height: root.screen-height;

    in-out property <length> screen-width: 750px;
    in-out property <length> screen-height: 474px;
    in-out property <length> panel-x: (root.width - root.panel-width) / 2;
    in-out property <length> panel-y: (root.height - root.panel-height) / 2;
    in-out property <bool> dragging;
    in-out property <bool> panel-centered-x;
    in-out property <bool> panel-centered-y;
    in-out property <string> search-text;
    in-out property <length> drag-area-height: 58px;

    private property <length> panel-width: 750px;
    private property <length> panel-height: 474px;
    private property <length> search-field-x: 14px;
    private property <length> search-field-width: 562px;
    private property <length> search-field-height: 44px;
    private property <length> search-field-padding: 12px;
    private property <length> content-padding-x: 22px;
    private property <length> footer-height: 28px;
    private property <length> suggestion-row-height: 54px;
    private property <length> guide-step: 30px;
    private property <length> guide-segment: 10px;

    no-frame: true;
    always-on-top: true;
    background: transparent;
    resize-border-width: 0px;
    forward-focus: search-input;

    init => {
        search-input.focus();
    }

    for dash in 400: Rectangle {
        x: root.width / 2 - root.panel-width / 2 - self.width / 2;
        y: dash * root.guide-step;
        opacity: root.dragging ? 1 : 0;
        width: root.panel-centered-x ? 4px : 2px;
        height: root.guide-segment;
        border-radius: 2px;
        background: root.panel-centered-x ? #ffffffcc : #ffffff55;

        animate opacity { duration: 160ms; easing: ease-out; }
        animate width { duration: 120ms; easing: ease-out; }
        animate background { duration: 120ms; easing: ease-out; }
    }

    for dash in 400: Rectangle {
        x: root.width / 2 + root.panel-width / 2 - self.width / 2;
        y: dash * root.guide-step;
        opacity: root.dragging ? 1 : 0;
        width: root.panel-centered-x ? 4px : 2px;
        height: root.guide-segment;
        border-radius: 2px;
        background: root.panel-centered-x ? #ffffffcc : #ffffff55;

        animate opacity { duration: 160ms; easing: ease-out; }
        animate width { duration: 120ms; easing: ease-out; }
        animate background { duration: 120ms; easing: ease-out; }
    }

    for dash in 600: Rectangle {
        x: dash * root.guide-step;
        y: root.height / 2 - root.panel-height / 2 - self.height / 2;
        opacity: root.dragging && root.panel-centered-x ? 1 : 0;
        width: root.guide-segment;
        height: root.panel-centered-y ? 4px : 2px;
        border-radius: 2px;
        background: root.panel-centered-y ? #ffffffcc : #ffffff55;

        animate opacity { duration: 160ms; easing: ease-out; }
        animate height { duration: 120ms; easing: ease-out; }
        animate background { duration: 120ms; easing: ease-out; }
    }

    for dash in 600: Rectangle {
        x: dash * root.guide-step;
        y: root.height / 2 + root.panel-height / 2 - self.height / 2;
        opacity: root.dragging && root.panel-centered-x ? 1 : 0;
        width: root.guide-segment;
        height: root.panel-centered-y ? 4px : 2px;
        border-radius: 2px;
        background: root.panel-centered-y ? #ffffffcc : #ffffff55;

        animate opacity { duration: 160ms; easing: ease-out; }
        animate height { duration: 120ms; easing: ease-out; }
        animate background { duration: 120ms; easing: ease-out; }
    }

    panel := Rectangle {
        x: root.panel-x;
        y: root.panel-y;
        width: root.panel-width;
        height: root.panel-height;
        background: #1c1c1eee;
        border-width: 1px;
        border-color: #ffffff14;
        border-radius: 15px;
        clip: true;

        Rectangle {
            width: 100%;
            height: root.drag-area-height;
            background: #242426cc;
        }

        Rectangle {
            y: root.drag-area-height - self.height;
            width: 100%;
            height: 1px;
            background: #ffffff12;
        }

        TouchArea {
            width: root.search-field-x;
            height: root.drag-area-height;
            mouse-cursor: MouseCursor.grab;
        }

        TouchArea {
            x: root.search-field-x + root.search-field-width;
            width: parent.width - self.x;
            height: root.drag-area-height;
            mouse-cursor: MouseCursor.grab;
        }

        Rectangle {
            x: root.search-field-x;
            y: (root.drag-area-height - root.search-field-height) / 2;
            width: root.search-field-width;
            height: root.search-field-height;
            background: transparent;
            clip: true;

            Text {
                visible: root.search-text == "";
                x: root.search-field-padding;
                width: parent.width - root.search-field-padding * 2;
                height: 100%;
                text: "Search an apps and other things...";
                color: #ffffff80;
                font-size: 17px;
                font-weight: 500;
                horizontal-alignment: left;
                vertical-alignment: center;
            }

            search-input := TextInput {
                x: root.search-field-padding;
                width: parent.width - root.search-field-padding * 2;
                height: 100%;
                text <=> root.search-text;
                color: #fffffff2;
                font-size: 17px;
                font-weight: 500;
                single-line: true;
                text-cursor-width: 2px;
                horizontal-alignment: left;
                vertical-alignment: center;
                selection-background-color: #ff63634d;
                selection-foreground-color: #ffffff;
            }
        }

        Rectangle {
            y: root.drag-area-height;
            width: 100%;
            height: parent.height - root.drag-area-height - root.footer-height;
            background: transparent;

            Text {
                x: root.content-padding-x;
                y: 18px;
                width: parent.width - root.content-padding-x * 2;
                height: 20px;
                text: "Suggestions";
                color: #ffffffb8;
                font-size: 16px;
                font-weight: 500;
                horizontal-alignment: left;
                vertical-alignment: center;
            }

            SuggestionItem {
                x: root.content-padding-x;
                y: 50px;
                width: parent.width - root.content-padding-x * 2;
                height: root.suggestion-row-height;
                title: "Open Neopad";
                subtitle: "Application";
                accent: #ff6363;
                icon-kind: 0;
            }

            SuggestionItem {
                x: root.content-padding-x;
                y: 50px + root.suggestion-row-height + 7px;
                width: parent.width - root.content-padding-x * 2;
                height: root.suggestion-row-height;
                title: "Create note";
                subtitle: "Quick action";
                accent: #6fd6b5;
                icon-kind: 1;
            }

            SuggestionItem {
                x: root.content-padding-x;
                y: 50px + (root.suggestion-row-height + 7px) * 2;
                width: parent.width - root.content-padding-x * 2;
                height: root.suggestion-row-height;
                title: "Search files";
                subtitle: "Workspace";
                accent: #72a7ff;
                icon-kind: 2;
            }
        }

        Rectangle {
            y: parent.height - root.footer-height;
            width: 100%;
            height: 1px;
            background: #ffffff10;
        }

        Rectangle {
            y: parent.height - root.footer-height;
            width: 100%;
            height: root.footer-height;
            background: #18181acc;

            Text {
                x: root.content-padding-x;
                width: parent.width - root.content-padding-x * 2;
                height: 100%;
                text: "Enter to open";
                color: #ffffff70;
                font-size: 11px;
                font-weight: 500;
                horizontal-alignment: left;
                vertical-alignment: center;
            }

            Text {
                x: root.content-padding-x;
                width: parent.width - root.content-padding-x * 2;
                height: 100%;
                text: "Esc to close";
                color: #ffffff70;
                font-size: 11px;
                font-weight: 500;
                horizontal-alignment: right;
                vertical-alignment: center;
            }
        }
    }
}
